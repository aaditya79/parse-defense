\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textsc  {Parse}\xspace  pipeline. Steps~1 and~1.5 run in parallel. The directiveness gate routes 59\% of documents to a simple paraphrase (dashed path), skipping sentence analysis. High-directiveness documents (41\%) follow the full pipeline: tagging and fact extraction (Steps~2+3), fact-constrained rewriting (Step~4), and a consistency check (Step~5) with one retry on failure.}}{3}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:pipeline}{{1}{3}{\parse pipeline. Steps~1 and~1.5 run in parallel. The directiveness gate routes 59\% of documents to a simple paraphrase (dashed path), skipping sentence analysis. High-directiveness documents (41\%) follow the full pipeline: tagging and fact extraction (Steps~2+3), fact-constrained rewriting (Step~4), and a consistency check (Step~5) with one retry on failure}{figure.caption.1}{}}
