\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces ASR (\%) by domain and overall; utility (\%) overall. Significance vs.\ baseline: * $p{<}0.05$, ** $p{<}0.01$ (McNemar's exact, uncorrected). parse\_dc = parse\_domain\_conditional. Utility for ablation conditions not measured (---). Domain-level differences are exploratory ($n{=}23$--$25$ per domain, underpowered for individual comparisons).}}{5}{table.caption.8}\protected@file@percent }
\newlabel{tab:main}{{1}{5}{ASR (\%) by domain and overall; utility (\%) overall. Significance vs.\ baseline: * $p{<}0.05$, ** $p{<}0.01$ (McNemar's exact, uncorrected). parse\_dc = parse\_domain\_conditional. Utility for ablation conditions not measured (---). Domain-level differences are exploratory ($n{=}23$--$25$ per domain, underpowered for individual comparisons)}{table.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces (a)~ASR--utility trade-off for all evaluated conditions. Lower ASR and higher utility is better (lower-right is optimal). \textsc  {Parse}\xspace  is the only condition simultaneously below 20\% ASR and above 85\% utility. Llama Guard achieves similarly low ASR but at a 27 percentage-point utility cost. (b)~Per-domain ASR for baseline vs.\ \textsc  {Parse}\xspace  . \textsc  {Parse}\xspace  reduces ASR in every domain; largest reductions are in financial (33.3\%$\to $12.5\%) and DevOps (24.0\%$\to $12.0\%).}}{5}{figure.caption.9}\protected@file@percent }
\newlabel{fig:results}{{2}{5}{(a)~ASR--utility trade-off for all evaluated conditions. Lower ASR and higher utility is better (lower-right is optimal). \parse is the only condition simultaneously below 20\% ASR and above 85\% utility. Llama Guard achieves similarly low ASR but at a 27 percentage-point utility cost. (b)~Per-domain ASR for baseline vs.\ \parse . \parse reduces ASR in every domain; largest reductions are in financial (33.3\%$\to $12.5\%) and DevOps (24.0\%$\to $12.0\%)}{figure.caption.9}{}}
